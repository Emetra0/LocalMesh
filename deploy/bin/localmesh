#!/usr/bin/env bash
set -euo pipefail

install_root="${LOCALMESH_INSTALL_ROOT:-/opt/localmesh}"
compose_file="${LOCALMESH_COMPOSE_FILE:-$install_root/docker/docker-compose.yml}"

usage() {
  cat <<'EOF'
Usage: localmesh <command>

Commands:
  status               Show status of all LocalMesh services
  restart              Restart the entire LocalMesh stack
  logs <service>       Tail logs for a service (api | adguard | nginx | all)
  cert generate <domain>   Generate a TLS cert for a local domain
  update               Pull latest code and rebuild the stack
  backup               Archive data to a timestamped tarball
  restore <archive>    Restore data from a tarball
EOF
}

require_arg() {
  if [[ -z "${2:-}" ]]; then
    echo "Missing argument for $1" >&2
    exit 1
  fi
}

case "${1:-}" in
  status)
    docker compose -f "$compose_file" ps
    ;;

  restart)
    docker compose -f "$compose_file" restart
    ;;

  logs)
    require_arg logs "${2:-}"
    case "$2" in
      api)
        docker logs --tail 200 -f localmesh-app
        ;;
      adguard)
        docker logs --tail 200 -f localmesh-adguard
        ;;
      nginx)
        docker logs --tail 200 -f localmesh-nginx
        ;;
      all)
        docker compose -f "$compose_file" logs --tail 100 -f
        ;;
      *)
        echo "Unknown service: $2 (valid: api | adguard | nginx | all)" >&2
        exit 1
        ;;
    esac
    ;;

  cert)
    require_arg cert "${2:-}"
    require_arg cert "${3:-}"
    case "$2" in
      generate)
        domain="$3"
        # Run mkcert inside the localmesh container where the CA lives
        docker exec \
          -e CAROOT=/ca \
          localmesh-app \
          mkcert \
            -cert-file "/certs/${domain}.pem" \
            -key-file "/certs/${domain}-key.pem" \
            "$domain"
        ;;
      *)
        echo "Unknown cert command: $2" >&2
        exit 1
        ;;
    esac
    ;;

  update)
    echo "Pulling latest code..."
    git -C "$install_root" fetch --all --prune
    git -C "$install_root" pull --ff-only || true

    echo "Rebuilding LocalMesh image..."
    docker compose -f "$compose_file" build localmesh

    echo "Restarting LocalMesh (AdGuard and NPM keep running)..."
    docker compose -f "$compose_file" up -d --no-deps localmesh
    ;;

  backup)
    timestamp="$(date +%Y%m%d-%H%M%S)"
    archive="$install_root/localmesh-backup-$timestamp.tar.gz"
    tar -czf "$archive" \
      -C "$install_root" \
      ca certs data docker/docker-compose.yml
    echo "$archive"
    ;;

  restore)
    require_arg restore "${2:-}"
    tar -xzf "$2" -C "$install_root"
    docker compose -f "$compose_file" restart
    ;;

  *)
    usage
    exit 1
    ;;
esac
