#!/usr/bin/env bash
set -euo pipefail

install_root="${LOCALMESH_INSTALL_ROOT:-/opt/localmesh}"
compose_file="${LOCALMESH_COMPOSE_FILE:-$install_root/docker/docker-compose.yml}"
service_name="${LOCALMESH_SERVICE_NAME:-localmesh.service}"
stack_service_name="${LOCALMESH_STACK_SERVICE_NAME:-localmesh-stack.service}"
repo_root="${LOCALMESH_REPO_ROOT:-$install_root}"
backup_dir="$install_root"

if [[ ! -f "$compose_file" && -f "$repo_root/deploy/docker/docker-compose.yml" ]]; then
  compose_file="$repo_root/deploy/docker/docker-compose.yml"
fi

usage() {
  cat <<'EOF'
Usage: localmesh <command>

Commands:
  status
  restart
  logs <service>
  cert generate <domain>
  update
  backup
  restore <backup.tar.gz>
EOF
}

require_arg() {
  if [[ -z "${2:-}" ]]; then
    echo "Missing argument for $1" >&2
    exit 1
  fi
}

case "${1:-}" in
  status)
    systemctl --no-pager --full status "$service_name" || true
    systemctl --no-pager --full status "$stack_service_name" || true
    docker compose -f "$compose_file" ps
    ;;
  restart)
    systemctl restart "$stack_service_name"
    systemctl restart "$service_name"
    ;;
  logs)
    require_arg logs "${2:-}"
    case "$2" in
      adguard)
        docker logs --tail 200 -f localmesh-adguard
        ;;
      nginx)
        docker logs --tail 200 -f localmesh-nginx
        ;;
      mkcert)
        docker logs --tail 200 -f localmesh-mkcert
        ;;
      *)
        echo "Unknown service: $2" >&2
        exit 1
        ;;
    esac
    ;;
  cert)
    require_arg cert "${2:-}"
    require_arg cert "${3:-}"
    case "$2" in
      generate)
        domain="$3"
        docker exec -e CAROOT=/ca localmesh-mkcert \
          mkcert \
          -cert-file "/certs/${domain}.pem" \
          -key-file "/certs/${domain}-key.pem" \
          "$domain"
        ;;
      *)
        echo "Unknown cert command: $2" >&2
        exit 1
        ;;
    esac
    ;;
  update)
    cd "$repo_root"
    git fetch --all --prune
    git pull --ff-only || true
    npm install
    npm run build
    docker compose -f "$compose_file" pull
    systemctl restart "$stack_service_name"
    systemctl restart "$service_name"
    ;;
  backup)
    timestamp="$(date +%Y%m%d-%H%M%S)"
    archive="$backup_dir/localmesh-backup-$timestamp.tar.gz"
    tar -czf "$archive" \
      -C "$install_root" \
      ca certs data docker/docker-compose.yml
    echo "$archive"
    ;;
  restore)
    require_arg restore "${2:-}"
    tar -xzf "$2" -C "$install_root"
    systemctl restart "$stack_service_name"
    systemctl restart "$service_name"
    ;;
  *)
    usage
    exit 1
    ;;
esac
