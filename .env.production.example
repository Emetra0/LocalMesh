LOCALMESH_SERVER_IP=auto-detected-during-install
LOCALMESH_API_PORT=2690
LOCALMESH_INSTALL_ROOT=/opt/localmesh
LOCALMESH_COMPOSE_FILE=/opt/localmesh/docker/docker-compose.yml
LOCALMESH_CLI_PATH=/usr/local/bin/localmesh
LOCALMESH_CERTS_DIR=/opt/localmesh/certs
LOCALMESH_CA_DIR=/opt/localmesh/ca
LOCALMESH_UPDATE_TOKEN=replace-with-random-secret
# AdGuard Home credentials (complete the AdGuard first-run wizard at :3000 first)
LOCALMESH_ADGUARD_USERNAME=admin
LOCALMESH_ADGUARD_PASSWORD=replace-me
# Nginx Proxy Manager credentials (complete the NPM first-run wizard at :81 first)
LOCALMESH_NPM_IDENTITY=admin@example.com
LOCALMESH_NPM_SECRET=replace-me
# NOTE: LOCALMESH_ADGUARD_URL and LOCALMESH_NPM_API_URL are intentionally
# omitted here — docker-compose.yml overrides them with Docker-internal
# service names (http://adguard:3000 and http://nginx-proxy-manager:81)
# so containers can talk to each other directly.